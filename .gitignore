# macOS folder metadata.
.DS_Store

# Beads / Dolt files (added by bd init)
.dolt/
*.db
*.db-wal
*.db-shm
.beads-credential-key

# Go build artifacts: the single binary (`make build`) and the
# cross-compiled linux/amd64 binary (`make build-linux`) for the GCP VM.
/photo-server
/photo-server-linux-amd64

# Local dev data dir (SQLite + photos). On the device this is the
# systemd StateDirectory at /var/lib/photo-server, never in-repo.
/data/

# Editor swap/backup files (vim, emacs, …).
*.swp
*.swo
*~
