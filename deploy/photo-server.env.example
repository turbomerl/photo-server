# /etc/photo-server/photo-server.env — operator config for the
# wedding appliance. Copy this file there, edit, then `systemctl
# restart photo-server`.
#
# Lines without `=` are ignored; values may be quoted.

# Bind to port 80 so guests reach http://photos.wedding/ without :8080.
# CAP_NET_BIND_SERVICE is granted by the systemd unit so we can bind
# a low port without running as root.
PHOTO_SERVER_ADDR=:80

# Public URL guests land on after joining wifi (printed on the QR
# card). Hostname matches dnsmasq's address=/photos.wedding/… entry.
PHOTO_SERVER_BASE_URL=http://photos.wedding/

# Hosts served as the app. Any other Host (= an OS captive probe like
# captive.apple.com) gets 302'd to BASE_URL so iOS/Android pop their
# "Sign in to network" sheet at the album (kgu.6, in-server replacement
# for opennds).
PHOTO_SERVER_ALLOWED_HOSTS=photos.wedding,192.168.50.1,127.0.0.1,localhost

# Wifi credentials baked into the printed QR (kgu.21). MUST match what
# you set on the UAP-AC-LR. Passphrase length 8–63 per WPA2.
PHOTO_SERVER_SSID=photo-server
PHOTO_SERVER_WIFI_PSK=photos2026

# Admin password (HTTP Basic on /admin*). Empty = admin disabled
# entirely (fail-closed). Set BEFORE the event.
PHOTO_SERVER_ADMIN_PASSWORD=change-me

# Optional: data dir defaults to the systemd StateDirectory
# /var/lib/photo-server — usually leave unset.
# PHOTO_SERVER_DATA_DIR=/var/lib/photo-server
